     "text": [
      "Best-fit parameters:\n",
      "  beta  = 0.490\n",
      "  sigma = 0.410  (incubation period ~ 2.4 days)\n",
      "  gamma = 0.220  (infectious period ~ 4.5 days)\n",
      "  R0    = beta/gamma = 2.23\n",
